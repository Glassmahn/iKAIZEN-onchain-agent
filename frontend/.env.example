# ============================================
# FRONTEND ENVIRONMENT CONFIGURATION
# ============================================
# Copy this file to .env.local and fill in your values

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3001

# Web3 Configuration
# 0G Galileo Testnet Chain ID: 16602
NEXT_PUBLIC_0G_RPC_URL=https://evmrpc-testnet.0g.ai
NEXT_PUBLIC_0G_CHAIN_ID=16602

# Sepolia Testnet (for backup/testing)
NEXT_PUBLIC_SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
NEXT_PUBLIC_SEPOLIA_CHAIN_ID=11155111

# Wallet Connection (RainbowKit)
# Get your WalletConnect Project ID from: https://cloud.walletconnect.com
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=

# Contract Addresses (0G Galileo Testnet)
# AgentNFT iNFT Contract - Main proxy for minting and managing iNFTs
NEXT_PUBLIC_AGENT_NFT_ADDRESS=0x1515d22b7Ea637D69c760C3986373FB976d96E8F

# AgentNFT Beacon (for upgrades)
NEXT_PUBLIC_AGENT_NFT_BEACON=0x98681D02CE70885CBb477de0b228fb1bc03294da

# AgentNFT Implementation
NEXT_PUBLIC_AGENT_NFT_IMPL=0x443145E9c157F603DAc896E0093713715b3019a3

# AgentMarket Contract - Marketplace for trading iNFTs
NEXT_PUBLIC_AGENT_MARKET_ADDRESS=0x

# TEEVerifier Contract - Trusted Execution Environment oracle
NEXT_PUBLIC_TEE_VERIFIER_ADDRESS=0x

# Verifier Contract - Transfer proof verification
NEXT_PUBLIC_VERIFIER_ADDRESS=0x

# Price Feed Configuration
# CoinGecko API (free, no key needed)
NEXT_PUBLIC_COINGECKO_API_URL=https://api.coingecko.com/api/v3

# Token Price IDs (CoinGecko format)
NEXT_PUBLIC_ETH_GECKO_ID=ethereum
NEXT_PUBLIC_USDC_GECKO_ID=usd-coin
NEXT_PUBLIC_OG_GECKO_ID=0g

# Trading Pairs
NEXT_PUBLIC_UNISWAP_V3_ROUTER=0x

# Social Links
NEXT_PUBLIC_TWITTER_URL=https://twitter.com/ifu_naya2
NEXT_PUBLIC_GITHUB_URL=https://github.com/glassmahn/iKAIZEN-onchain-agent
NEXT_PUBLIC_DOCS_URL=https://medium.com/@glassman4664/ikaizen-onchain-agent-537cbc3862d5

# Feature Flags
NEXT_PUBLIC_ENABLE_LIVE_PRICE_FEED=true
NEXT_PUBLIC_ENABLE_REAL_TIME_UPDATES=true
NEXT_PUBLIC_AUTO_REFRESH_INTERVAL=30000

# Debugging
NEXT_PUBLIC_DEBUG_MODE=false
